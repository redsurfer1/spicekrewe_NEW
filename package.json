{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "verify:content": "node scripts/verify-blog-registry.mjs",
    "prebuild": "npm run verify:content && tsx scripts/build-blog-registry.ts && node scripts/generate-og-image.js",
    "predev": "tsx scripts/build-blog-registry.ts",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsx scripts/build-blog-registry.ts && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.server.json",
    "generate:og": "node scripts/generate-og-image.js",
    "check-links": "node scripts/check-internal-links.js",
    "retention:check": "tsx scripts/retention-check.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@google/genai": "^1.41.0",
    "@stripe/react-stripe-js": "^2.9.0",
    "@stripe/stripe-js": "^4.10.0",
    "@supabase/supabase-js": "^2.57.4",
    "gray-matter": "^4.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "marked": "^17.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.13.1",
    "resend": "^4.0.1",
    "stripe": "^17.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^4.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.18",
    "canvas": "^3.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^8.0.3",
    "vite-plugin-sitemap": "^0.8.2"
  }
}
