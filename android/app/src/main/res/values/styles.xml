<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <!-- Spice Krewe Brand Alignment -->
        <item name="colorPrimary">@color/sk_purple</item>
        <item name="colorPrimaryDark">@color/sk_navy</item>
        <item name="colorAccent">@color/sk_gold</item>
        <item name="android:windowBackground">@color/sk_surface</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="colorPrimary">@color/sk_purple</item>
        <item name="colorPrimaryDark">@color/sk_navy</item>
        <item name="colorAccent">@color/sk_gold</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/sk_navy</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
