# Spice Krewe — environment template. Copy to `.env` / Vercel. Never commit real secrets.

# --- Client (Vite `VITE_*` — may be exposed in the browser bundle) ---
VITE_APP_ORIGIN=
VITE_GEMINI_API_KEY=

# Airtable: directory (Professionals) read-only from the client using a read-scoped token.
# Briefs writes MUST use server-only AIRTABLE_SECRET_PAT via /api/submit-brief — do not use a full PAT in VITE_.
VITE_AIRTABLE_API_KEY=
VITE_AIRTABLE_BASE_ID=
VITE_AIRTABLE_PROFESSIONALS_TABLE=Professionals

VITE_STRIPE_PUBLIC_KEY=
# Sprint 5 — publishable key for Stripe.js (`getStripe()`). Never put secret keys in VITE_*.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace
# Legacy featured checkout endpoint (removed from HireFlow UI — clean model). May remain for server routes until retired.
VITE_STRIPE_CHECKOUT_ENDPOINT_URL=

# SpiceKrewe API — concierge and bookings. Relative paths used by default.
# Set only if deploying API separately from the client (uncommon).
# VITE_API_BASE_URL=https://your-domain.com
# Deprecated: concierge buyer id now comes from signed-in user (`spicekrewe_auth_user` via useAuth).
VITE_CONCIERGE_DEMO_BUYER_ID=

# Anthropic Claude AI (concierge)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# Concierge operator notifications
CONCIERGE_OPS_EMAIL=

# HMAC secret for public credential JSON + SVG badge endpoints (`/api/credentials-public`, `/api/credentials-badge`).
CREDENTIALS_SIGNING_SECRET=

# Used to validate review tokens in `/api/submit-review` (HMAC of bookingId + buyerId).
REVIEW_SIGNING_SECRET=

# --- Server / Vercel (`api/*` — never prefix with VITE_) ---
# Airtable: full PAT for Briefs table (serverless only). Also referenced as “API key” in ops docs.
AIRTABLE_SECRET_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_BRIEFS_TABLE=Briefs

# Stripe: secret key (NOT VITE). Often named STRIPE_SECRET in docs; this repo uses STRIPE_SECRET_KEY.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Connect transfers (separate webhook endpoint)
STRIPE_CONNECT_WEBHOOK_SECRET=

# Vercel Cron — optional shared secret (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Automation tuning
PROVIDER_DECLINE_WINDOW_HOURS=24
REVENUE_DROP_ALERT_THRESHOLD=0.20

# Admin session (server-verified login + signed token for /api/admin/health)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Optional CORS: lock API to your web origin (e.g. https://spicekrewe.com)
SERVER_ALLOWED_ORIGIN=

# Supabase (server-side; same project as VITE_SUPABASE_* when using Supabase-hosted Postgres)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email — onboarding + alerts)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@spicekrewe.com

# SLA monitor / ops alerts (Edge Functions + optional Vercel paths)
SLACK_WEBHOOK_URL=
ADMIN_ALERT_EMAIL=

# GitHub Actions CI — add these as repo secrets (Settings → Secrets → Actions → New repository secret)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
